{
  "name": "@network/server",
  "version": "1.0.0",
  "description": "API server — Express, Socket.io, MongoDB, BullMQ",
  "author": {
    "name": "Rahul Kesharwani"
  },
  "private": true,
  "type": "module",
  "main": "dist/web.js",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "tsx watch src/web.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc --build tsconfig.build.json",
    "start": "npm run start:web",
    "start:web": "node dist/web.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "@aws-sdk/s3-request-presigner": "^3.1061.0",
    "@network/shared": "^1.0.0",
    "@node-rs/argon2": "^2.0.2",
    "@sentry/node": "^10.56.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "arctic": "^3.7.0",
    "bullmq": "^5.79.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "file-type": "^22.0.1",
    "helmet": "^8.2.0",
    "ioredis": "5.10.1",
    "jose": "^6.2.3",
    "mongoose": "^9.6.3",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.12.4",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
    "sirv": "^3.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.4",
    "@types/nodemailer": "^8.0.1",
    "@types/sanitize-html": "^2.16.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
