# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Cryptographic Keys
JWT_SECRET=replace_with_a_random_64_char_hex_string

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.example.mongodb.net/?appName=Cluster
DB_NAME=network
REDIS_URI=rediss://default:<password>@<host>:<port>

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback

# Email — shared
EMAIL_FROM=noreply@yourdomain.com

# Resend — dev/test only
RESEND_API_KEY=re_your_resend_api_key

# SMTP — production only
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Cloudflare R2
CF_ACCOUNT_ID=your_cf_account_id
CF_API_TOKEN=your_cf_api_token
CF_R2_ACCESS_KEY_ID=your_r2_access_key
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CF_R2_BUCKET_NAME=your-bucket-name
CF_PUBLIC_URL=https://pub-yourpublicid.r2.dev

# Logging
LOG_LEVEL=info
