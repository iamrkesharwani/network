{
  "name": "network",
  "version": "1.0.0",
  "description": "Monorepo — Social network site",
  "author": {
    "name": "Rahul Kesharwani"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=@network/client",
    "dev:web": "npm run dev:web --workspace=@network/server",
    "dev:worker": "npm run dev:worker --workspace=@network/server",
    "build:shared": "npm run build --workspace=@network/shared",
    "build:client": "npm run build --workspace=@network/client",
    "build:server": "npm run build --workspace=@network/server",
    "build": "npm run build:shared && npm run build:client && npm run build:server",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "i:client": "npm install --workspace=@network/client",
    "i:server": "npm install --workspace=@network/server",
    "i:shared": "npm install --workspace=@network/shared",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:status": "docker compose ps"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
